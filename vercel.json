{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/services/basement-waterproofing",
      "destination": "/services/mold-remediation",
      "permanent": true
    },
    {
      "source": "/services/crawlspace-encapsulation",
      "destination": "/services/mold-inspection",
      "permanent": true
    },
    {
      "source": "/services/water-damage",
      "destination": "/services/mold-remediation",
      "permanent": true
    },
    {
      "source": "/services/clearance-air-testing",
      "destination": "/services/clearance-testing",
      "permanent": true
    }
  ]
}